{
    "name": "nicxonsolutions/rajaongkir",
    "description": "Laravel package for RajaOngkir/Komerce destination search and shipping cost calculation.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/robertnicjoo/rajaongkir",
    "authors": [
        {
            "name": "Nicxon Solutions",
            "email": "dev@nicxonsolutions.com",
            "homepage": "https://nicxonsolutions.com"
        },
        {
            "name": "Robert Nicjoo",
            "homepage": "https://github.com/robertnicjoo"
        }
    ],
    "support": {
        "issues": "https://github.com/robertnicjoo/rajaongkir/issues",
        "source": "https://github.com/robertnicjoo/rajaongkir"
    },
    "autoload": {
        "psr-4": {
            "Nicxonsolutions\\Rajaongkir\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nicxonsolutions\\Rajaongkir\\RajaongkirServiceProvider"
            ],
            "aliases": {
                "Rajaongkir": "Nicxonsolutions\\Rajaongkir\\Facades\\Rajaongkir"
            }
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/http": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/session": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
